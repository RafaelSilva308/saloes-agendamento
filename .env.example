# Google OAuth (opcional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
